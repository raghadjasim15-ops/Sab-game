<!DOCTYPE html>
<html>
<head>
  <title>Steal a Brainrot</title>
  <style>
    body {
      font-family: Arial;
      background: linear-gradient(135deg, #0f0f0f, #1a1a1a);
      color: white;
      text-align: center;
    }

    h1 {
      margin-top: 20px;
    }

    .shop {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
    }

    .item {
      background: #222;
      border-radius: 15px;
      padding: 20px;
      margin: 15px;
      width: 200px;
      box-shadow: 0 0 10px #000;
    }

    button {
      background: lime;
      border: none;
      padding: 10px;
      border-radius: 8px;
      cursor: pointer;
      margin-top: 10px;
      font-weight: bold;
    }

    button:hover {
      background: #00cc00;
    }

    #inventory {
      margin-top: 30px;
      padding: 20px;
      background: #181818;
      border-radius: 10px;
      display: inline-block;
    }

    #popup {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0,0,0,0.8);
    }

    #popup-content {
      background: #222;
      padding: 30px;
      border-radius: 10px;
      margin-top: 150px;
      display: inline-block;
    }
  </style>
</head>

<body>

<h1>🧠 Steal a Brainrot</h1>
<p>Buy brainrots and build your collection!</p>

<h2>💰 Coins: <span id="coins">50</span></h2>

<div class="shop">

  <div class="item">
    <h3>Skibidi Brainrot</h3>
    <p>10 Coins</p>
    <button onclick="buy('Skibidi Brainrot', 10)">Buy</button>
  </div>

  <div class="item">
    <h3>Ohio Brainrot</h3>
    <p>15 Coins</p>
    <button onclick="buy('Ohio Brainrot', 15)">Buy</button>
  </div>

  <div class="item">
    <h3>Sigma Brainrot</h3>
    <p>25 Coins</p>
    <button onclick="buy('Sigma Brainrot', 25)">Buy</button>
  </div>

</div>

<div id="inventory">
  <h2>🎒 Your Brainrots</h2>
  <ul id="items"></ul>
</div>

<div id="popup">
  <div id="popup-content">
    <h2>💸 Swish Payment</h2>
    <p id="payment-text"></p>
    <button onclick="confirmPayment()">I Paid</button>
  </div>
</div>

<script>
let coins = 50;
let selectedItem = "";
let selectedPrice = 0;

function buy(item, price) {
  selectedItem = item;
  selectedPrice = price;

  document.getElementById("payment-text").innerText =
    "Send " + price + " SEK via Swish to: 123-456-7890";

  document.getElementById("popup").style.display = "block";
}

function confirmPayment() {
  if (coins >= selectedPrice) {
    coins -= selectedPrice;
    document.getElementById("coins").innerText = coins;

    let li = document.createElement("li");
    li.innerText = selectedItem;
    document.getElementById("items").appendChild(li);

    alert("✅ You got " + selectedItem + "!");
  } else {
    alert("❌ Not enough coins!");
  }

  document.getElementById("popup").style.display = "none";
}
</script>

</body>
</html>
